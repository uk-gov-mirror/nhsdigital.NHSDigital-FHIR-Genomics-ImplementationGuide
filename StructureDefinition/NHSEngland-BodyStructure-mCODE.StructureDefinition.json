        "path": "BodyStructure.patient",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://fhir.nhs.uk/StructureDefinition/NHSEngland-Patient-Genomics",
              "http://hl7.org/fhir/us/mcode/StructureDefinition/mcode-cancer-patient"
            ],
            "aggregation": [
              "referenced",
              "bundled"
            ]
          }
        ]
      }
    ]
  }
